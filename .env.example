# VoiceQuest 키 템플릿
# 사용법: 이 파일을 복사해 `.env`로 만들고, 실제 키를 채워 넣는다.
#   cp .env.example .env
# .env 는 .gitignore로 커밋 차단됨. 절대 깃/코드/채팅에 키를 노출하지 말 것.

# ─────────────────────────────────────────────
# 알파(실음성 1턴) 최소 — 이것만 있으면 시작된다
# ─────────────────────────────────────────────
DEEPGRAM_KEY=            # STT(음성→일본어 텍스트). console.deepgram.com 가입 무료 크레딧

# judge(판정) = 로컬 Qwen(Ollama) 무료 기본 → 아무것도 안 넣어도 됨.
#   이미 극한 튜닝됨(qwen3-coder:30b 상주). 엔드포인트는 코드 기본값(localhost:11434).

# ─────────────────────────────────────────────
# 풀 체험(NPC 음성·이미지) — 빌드타임 캐시용, 알파엔 선택
# ─────────────────────────────────────────────
MINIMAX_API_KEY=         # TTS(NPC 목소리). platform.minimax.io
GEMINI_KEY=              # 이미지(캐릭터·배경). aistudio.google.com 무료 500장/일
ANTHROPIC_API_KEY=       # (선택) 프로덕션급 judge·콘텐츠 생성 품질. console.anthropic.com

# ─────────────────────────────────────────────
# 계측·저장 — 알파엔 로컬 이벤트로 대체 가능
# ─────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_SERVICE_ACCOUNT=  # 서비스 계정 키 JSON(문자열) 또는 .json 파일 경로 — 있으면 Firestore(voicequest-dev), 없으면 data/events 파일 폴백
FIREBASE_PRIVATE_KEY=

# 운영자 콘솔 토큰 — 초대코드 발급 권한(로컬 생성)
ADMIN_TOKEN=
