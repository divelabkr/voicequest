        {
          "w": "座っ",
          "gloss": "앉다"
        }
      ],
      "bytes": 30159,
      "hash": "7effd60b"
    },
    {
      "text": "お、座れた？じゃあ注文決めよっか。何にする？",
      "audio": "audio/2f52598a.m4a",
      "furigana": "お、座(すわ)れた？じゃあ注文(ちゅうもん)決(き)めよっか。何(なに)にする？",
      "words": [
        {
          "w": "注文",
          "gloss": "주문"
        }
      ],
      "bytes": 25708,
      "hash": "2f52598a"
    },
    {
      "text": "あいよ、ラーメンね！…そうだ、初めてなら今日のおすすめも気になる？",
      "audio": "audio/fecd92b5.m4a",
      "furigana": "あいよ、ラーメンね！…そうだ、初(はじ)めてなら今日(きょう)のおすすめも気(き)になる？",
      "words": [],
      "bytes": 29910,
      "hash": "fecd92b5"
    },
    {
      "text": "ここの味噌ラーメン、まじで最高だよ！",
      "audio": "audio/ad73002c.m4a",
      "furigana": "ここの味噌(みそ)ラーメン、まじで最高(さいこう)だよ！",
      "words": [],
      "bytes": 27503,
      "hash": "ad73002c"
    },
    {
      "text": "はい、お待たせ！アツアツのラーメンだよ。…食べてみて、どう？",
      "audio": "audio/5e45a63f.m4a",
      "furigana": "はい、お待(ま)たせ！アツアツのラーメンだよ。…食(た)べてみて、どう？",
      "words": [],
      "bytes": 24787,
      "hash": "5e45a63f"
    },
    {
      "text": "おっ、きれいに完食だね！ありがとう。お会計する？",
      "audio": "audio/fdcad6b2.m4a",
      "furigana": "おっ、きれいに完(かん)食(しょく)だね！ありがとう。お会計(かいけい)する？",
      "words": [
        {
          "w": "会計",
          "gloss": "계산"
        }
      ],
      "bytes": 21236,
      "hash": "fdcad6b2"
    },
    {
      "text": "はい、ちょうどいただきました！今日はありがとね",
      "audio": "audio/93e6c367.m4a",
      "furigana": "はい、ちょうどいただきました！今日(きょう)はありがとね",
      "words": [],
      "bytes": 29904,
      "hash": "93e6c367"
    },
    {
      "text": "そういえば、君どこから来たの？日本の感想とか、よかったら聞かせてよ",
      "audio": "audio/8f71061d.m4a",
      "furigana": "そういえば、君(きみ)どこから来(き)たの？日本(にっぽん)の感想(かんそう)とか、よかったら聞(き)かせてよ",
      "words": [
        {
          "w": "感想",
          "gloss": "감상, 소감"
        }
      ],
      "bytes": 12675,
      "hash": "8f71061d"
    },
    {
      "text": "おっ、いいね！",
      "audio": "audio/cf83d830.m4a",
      "furigana": "おっ、いいね！",
      "words": [],
      "bytes": 12110,
