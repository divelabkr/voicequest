{
  "episode": "ep_01",
  "lines": [
    {
      "text": "いらっしゃいませ！",
      "audio": "/cache/_shared/audio/21fb12d4.m4a",
      "furigana": "いらっしゃいませ！",
      "words": [],
      "bytes": 9551,
      "hash": "21fb12d4"
    },
    {
      "text": "あ、今ちょっと混んでてね…まあまあ、立ち話もなんだし、座って座って",
      "audio": "/cache/_shared/audio/7effd60b.m4a",
      "furigana": "あ、今(いま)ちょっと混(こ)んでてね…まあまあ、立(た)ち話(ばなし)もなんだし、座(すわ)って座(すわ)って",
      "words": [
        {
          "w": "今",
          "gloss": "지금, 현재"
        },
        {
          "w": "混ん",
          "gloss": "붐비다"
        },
        {
          "w": "立ち話",
          "gloss": "선 채로 나누는 이야기"
        },
        {
          "w": "座っ",
          "gloss": "앉다"
        },
        {
          "w": "座っ",
          "gloss": "앉다"
        }
      ],
      "bytes": 30159,
      "hash": "7effd60b"
    },
    {
      "text": "お、座れた？じゃあ注文決めよっか。何にする？",
      "audio": "/cache/_shared/audio/2f52598a.m4a",
      "furigana": "お、座(すわ)れた？じゃあ注文(ちゅうもん)決(き)めよっか。何(なに)にする？",
      "words": [
        {
          "w": "注文",
          "gloss": "주문"
        }
      ],
      "bytes": 25708,
      "hash": "2f52598a"
    },
    {
      "text": "あいよ、ラーメンね！…そうだ、初めてなら今日のおすすめも気になる？",
      "audio": "/cache/_shared/audio/fecd92b5.m4a",
      "furigana": "あいよ、ラーメンね！…そうだ、初(はじ)めてなら今日(きょう)のおすすめも気(き)になる？",
      "words": [],
      "bytes": 29910,
      "hash": "fecd92b5"
    },
    {
      "text": "ここの味噌ラーメン、まじで最高だよ！",
      "audio": "/cache/_shared/audio/ad73002c.m4a",
      "furigana": "ここの味噌(みそ)ラーメン、まじで最高(さいこう)だよ！",
      "words": [],
      "bytes": 27503,
      "hash": "ad73002c"
    },
    {
      "text": "はい、お待たせ！アツアツのラーメンだよ。…食べてみて、どう？",
      "audio": "/cache/_shared/audio/5e45a63f.m4a",
      "furigana": "はい、お待(ま)たせ！アツアツのラーメンだよ。…食(た)べてみて、どう？",
      "words": [],
      "bytes": 24787,
      "hash": "5e45a63f"
    },
    {
      "text": "おっ、きれいに完食だね！ありがとう。お会計する？",
      "audio": "/cache/_shared/audio/fdcad6b2.m4a",
      "furigana": "おっ、きれいに完(かん)食(しょく)だね！ありがとう。お会計(かいけい)する？",
      "words": [
        {
          "w": "会計",
          "gloss": "계산"
        }
      ],
      "bytes": 21236,
      "hash": "fdcad6b2"
    },
    {
      "text": "はい、ちょうどいただきました！今日はありがとね",
      "audio": "/cache/_shared/audio/93e6c367.m4a",
      "furigana": "はい、ちょうどいただきました！今日(きょう)はありがとね",
      "words": [],
      "bytes": 29904,
      "hash": "93e6c367"
    },
    {
      "text": "そういえば、君どこから来たの？日本の感想とか、よかったら聞かせてよ",
      "audio": "/cache/_shared/audio/8f71061d.m4a",
      "furigana": "そういえば、君(きみ)どこから来(き)たの？日本(にっぽん)の感想(かんそう)とか、よかったら聞(き)かせてよ",
      "words": [
        {
          "w": "感想",
          "gloss": "감상, 소감"
        }
      ],
      "bytes": 12675,
      "hash": "8f71061d"
    },
    {
      "text": "おっ、いいね！",
      "audio": "/cache/_shared/audio/cf83d830.m4a",
      "furigana": "おっ、いいね！",
      "words": [],
      "bytes": 12110,
      "hash": "cf83d830"
    },
    {
      "text": "はいよ、了解！",
      "audio": "/cache/_shared/audio/e8bd8bf2.m4a",
      "furigana": "はいよ、了解(りょうかい)！",
      "words": [],
      "bytes": 16053,
      "hash": "e8bd8bf2"
    },
    {
      "text": "うん、なるほどね",
      "audio": "/cache/_shared/audio/76cceaec.m4a",
      "furigana": "うん、なるほどね",
      "words": [],
      "bytes": 16964,
      "hash": "76cceaec"
    },
    {
      "text": "また来てね！またいつでもおいで",
      "audio": "/cache/_shared/audio/33ea7245.m4a",
      "furigana": "また来(き)てね！またいつでもおいで",
      "words": [],
      "bytes": 11052,
      "hash": "33ea7245"
    },
    {
      "text": "もう一度どうぞ",
      "audio": "/cache/_shared/audio/41339aa7.m4a",
      "furigana": "もう一度(いちど)どうぞ",
      "words": [],
      "bytes": 12140,
      "hash": "41339aa7"
    },
    {
      "text": "うーん…",
      "audio": "/cache/_shared/audio/3708a967.m4a",
      "furigana": "うーん…",
      "words": [],
      "bytes": 11003,
      "hash": "3708a967"
    },
    {
      "text": "えーと…",
      "audio": "/cache/_shared/audio/b0db18be.m4a",
      "furigana": "えーと…",
      "words": [],
      "bytes": 11870,
      "hash": "b0db18be"
    },
    {
      "text": "あのー…",
      "audio": "/cache/_shared/audio/aac3ad7e.m4a",
      "furigana": "あのー…",
      "words": [],
      "bytes": 10851,
      "hash": "aac3ad7e"
    },
    {
      "text": "んー…",
      "audio": "/cache/_shared/audio/c6abd3e1.m4a",
      "furigana": "んー…",
      "words": [],
      "bytes": 12064,
      "hash": "c6abd3e1"
    },
    {
      "text": "君、出身はどこ？",
      "audio": "/cache/_shared/audio/e5d949b7.m4a",
      "furigana": "君(きみ)、出身(しゅっしん)はどこ？",
      "words": [],
      "bytes": 14524,
      "hash": "e5d949b7"
    },
    {
      "text": "好きな食べ物ってある？",
      "audio": "/cache/_shared/audio/c30281f6.m4a",
      "furigana": "好(す)きな食(た)べ物(もの)ってある？",
      "words": [],
      "bytes": 13765,
      "hash": "c30281f6"
    },
    {
      "text": "日本に来てどう？慣れた？",
      "audio": "/cache/_shared/audio/167547ee.m4a",
      "furigana": "日本(にっぽん)に来(き)てどう？慣(な)れた？",
      "words": [],
      "bytes": 16376,
      "hash": "167547ee"
    },
    {
      "text": "うちのラーメン、どうだった？",
      "audio": "/cache/_shared/audio/411bfc2b.m4a",
      "furigana": "うちのラーメン、どうだった？",
      "words": [],
      "bytes": 13352,
      "hash": "411bfc2b"
    },
    {
      "text": "休みの日は何してるの？",
      "audio": "/cache/_shared/audio/13cf40a8.m4a",
      "furigana": "休(やす)みの日(ひ)は何(なに)してるの？",
      "words": [],
      "bytes": 14094,
      "hash": "13cf40a8"
    },
    {
      "text": "へえ、いいね！もっと聞かせて。",
      "audio": "/cache/_shared/audio/2ebc0abc.m4a",
      "furigana": "へえ、いいね！もっと聞(き)かせて。",
      "words": [],
      "bytes": 16647,
      "hash": "2ebc0abc"
    },
    {
      "text": "なるほどね。",
      "audio": "/cache/_shared/audio/8115c474.m4a",
      "furigana": "なるほどね。",
      "words": [],
      "bytes": 12282,
      "hash": "8115c474"
    },
    {
      "text": "うーん、そっか。",
      "audio": "/cache/_shared/audio/36c747cf.m4a",
      "furigana": "うーん、そっか。",
      "words": [],
      "bytes": 16306,
      "hash": "36c747cf"
    },
    {
      "text": "ごめん、もう一度言ってくれる？",
      "audio": "/cache/_shared/audio/d227f971.m4a",
      "furigana": "ごめん、もう一度(いちど)言(い)ってくれる？",
      "words": [],
      "bytes": 16683,
      "hash": "d227f971"
    },
    {
      "text": "うーん、その話はやめておこうか。別のことを話そう。",
      "audio": "/cache/_shared/audio/3423aa9e.m4a",
      "furigana": "うーん、その話(はなし)はやめておこうか。別(べつ)のことを話(はな)そう。",
      "words": [],
      "bytes": 26824,
      "hash": "3423aa9e"
    }
