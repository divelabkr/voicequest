      "words": [],
      "bytes": 9551,
      "hash": "21fb12d4"
    },
    {
      "text": "あ、今ちょっと混んでてね…まあまあ、立ち話もなんだし、座って座って",
      "audio": "audio/7effd60b.m4a",
      "furigana": "あ、今(いま)ちょっと混(こ)んでてね…まあまあ、立(た)ち話(ばなし)もなんだし、座(すわ)って座(すわ)って",
      "words": [
        {
          "w": "今",
          "gloss": "지금, 현재"
        },
        {
          "w": "混ん",
          "gloss": "붐비다"
        },
        {
          "w": "立ち話",
          "gloss": "선 채로 나누는 이야기"
